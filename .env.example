# ─── Anthropic ────────────────────────────────────────────────────────────────
# Clé API Anthropic — https://console.anthropic.com/settings/keys
# Utilisée dans : api/naf.js, api/search.js
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Supabase (backend — Vercel Functions) ────────────────────────────────────
# URL de base du projet Supabase (sans /rest/v1/)
# Trouvée dans : Supabase Dashboard → Settings → API → Project URL
# Utilisée dans : api/rate-limit.js, api/export.js, api/export-quota.js
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé service_role — bypass RLS, NE PAS exposer côté client
# Trouvée dans : Supabase Dashboard → Settings → API → service_role
# Utilisée dans : api/rate-limit.js, api/export.js, api/export-quota.js
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Supabase (frontend — api/log.js via REST brut) ───────────────────────────
# URL REST complète, doit se terminer par /rest/v1/
# Trouvée dans : Supabase Dashboard → Settings → API → Project URL + /rest/v1/
# Utilisée dans : api/log.js (appel REST direct sans SDK)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co/rest/v1/

# Clé anon — sûre pour le navigateur, soumise aux politiques RLS
# Trouvée dans : Supabase Dashboard → Settings → API → anon public
# Utilisée dans : api/log.js
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
